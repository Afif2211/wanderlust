<% layout("/layouts/boilerplate") %>

<div class="hero-section">

    <div class="hero-overlay"></div>

    <div class="hero-content">

        <p class="welcome-text">Welcome to Wanderlust</p>

        <h1>
            Hi, I'm <span>Afif Ahmad</span>
        </h1>

        <p class="hero-description">
            A passionate Full-Stack Developer and Computer Science graduate.
            Wanderlust is my Airbnb-inspired web application where users can
            explore beautiful stays, upload listings, leave reviews, and
            discover amazing places around the world.
        </p>

        <div class="hero-buttons">
            <a href="/listings" class="explore-btn">
                Explore Listings
            </a>

            <a href="#tech-stack" class="secondary-btn">
                View Tech Stack
            </a>
        </div>

    </div>

</div>


<!-- ABOUT SECTION -->

<section class="about-section">

    <div class="about-card">

        <div class="about-left">

            <h2>About This Project</h2>

            <p>
                Wanderlust is a modern travel and property listing platform
                inspired by Airbnb. Users can create accounts, upload property
                listings with images, add reviews, manage their own listings,
                and explore locations with interactive maps.
            </p>

            <p>
                This project helped me strengthen my MERN-stack concepts,
                backend development skills, authentication systems,
                file uploads, cloud storage integration, and responsive UI design.
            </p>

        </div>

        <div class="about-right">

            <img
                src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?q=80&w=1200&auto=format&fit=crop"
                alt="Travel"
            >
        </div>

    </div>

</section>


<!-- TECH STACK -->

<section class="tech-section" id="tech-stack">

    <h2 class="section-title">Technologies Used</h2>

    <div class="tech-grid">

        <div class="tech-card">
            <i class="fa-brands fa-node-js"></i>
            <h3>Node.js</h3>
            <p>Backend runtime environment</p>
        </div>

        <div class="tech-card">
            <i class="fa-solid fa-server"></i>
            <h3>Express.js</h3>
            <p>Server-side framework</p>
        </div>

        <div class="tech-card">
            <i class="fa-solid fa-database"></i>
            <h3>MongoDB</h3>
            <p>NoSQL database for listings & users</p>
        </div>

        <div class="tech-card">
            <i class="fa-brands fa-bootstrap"></i>
            <h3>Bootstrap</h3>
            <p>Responsive UI components</p>
        </div>

        <div class="tech-card">
            <i class="fa-solid fa-cloud"></i>
            <h3>Cloudinary</h3>
            <p>Cloud image storage & uploads</p>
        </div>

        <div class="tech-card">
            <i class="fa-solid fa-map-location-dot"></i>
            <h3>Mapbox</h3>
            <p>Interactive maps & geolocation</p>
        </div>

    </div>

</section>


<!-- CTA SECTION -->

<section class="cta-section">

    <h2>Ready to Explore Amazing Places?</h2>

    <p>
        Discover beautiful destinations and unique stays around the world.
    </p>

    <a href="/listings" class="cta-btn">
        Start Exploring
    </a>

</section>